# ============================================
# LUKSO Testnet Deployment Configuration
# ============================================

# LUKSO deployer private key (with testnet LYX funds)
# Get testnet LYX from: https://faucet.testnet.lukso.network
PRIVATE_KEY=

# Base deployer private key (with Base Sepolia ETH funds)
# If not set, falls back to PRIVATE_KEY
# Get Base Sepolia ETH from: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
BASE_PRIVATE_KEY=

# Optional: contract verification on block explorers
ETHERSCAN_API_KEY=
BASE_ETHERSCAN_KEY=

# ============================================
# Auto-populated by scripts/deploy.ts
# ============================================

# Agent Vault Registry (factory contract)
REGISTRY_ADDRESS=

# Merchant Registry (on-chain merchant directory)
MERCHANT_REGISTRY_ADDRESS=

# Deployed demo vault addresses
AGENT_SAFE_ADDRESS=
KEY_MANAGER_ADDRESS=
POLICY_ENGINE_ADDRESS=

# Demo agent wallet (generated during deployment)
AGENT_PRIVATE_KEY=
AGENT_ADDRESS=

# ============================================
# Demo payment configuration
# ============================================

# Merchant address for testing (usually deployer.address)
MERCHANT_ADDRESS=

# Payment amount for demo (in LYX)
PAYMENT_AMOUNT=0.1

# ============================================
# UI: Optional Ito avatar (IPFS gateway URL)
# Set to an HTTP gateway for ipfs://bafy... content
NEXT_PUBLIC_ITO_AVATAR_URL=https://ipfs.io/ipfs/bafybeie7fj37puabmx3bzsnne2zw75qerfcrlzwtgv7l4bozsk5otz4bm4

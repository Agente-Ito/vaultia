# ============================================================
# Dependencies — never commit, always install from lockfile
# ============================================================
node_modules/

# ============================================================
# Secrets — NEVER commit private keys or API keys
# ============================================================
.env
# Use .env.example (committed, placeholder values only) instead

# ============================================================
# Build outputs — all regenerated by `npx hardhat compile`
# ============================================================
artifacts/
cache/
typechain-types/

# ============================================================
# Next.js outputs
# ============================================================
.next/
out/
build/

# ============================================================
# TypeScript
# ============================================================
*.tsbuildinfo

# ============================================================
# macOS
# ============================================================
.DS_Store
*.DS_Store

# ============================================================
# Logs
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ============================================================
# Coverage
# ============================================================
coverage/
